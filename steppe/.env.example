# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://cywpkhtpxekmjvuoloem.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_3I1RIBnXTapjMfNT1Gx-KQ_5PhQI1ZM
# Server-only secret key — used by lib/supabase/admin.ts (e.g. /api/interest).
# Never expose it to the client (do NOT prefix with NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# Launch phase gate (lib/supabase/proxy.ts).
#   prelaunch (default) — only the public marketing pages + the /join signup are
#                         served; /auth/* and /protected/* redirect to "/".
#   live                — opens the member app (normal auth gating).
LAUNCH_PHASE=prelaunch