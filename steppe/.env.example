# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://cywpkhtpxekmjvuoloem.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_3I1RIBnXTapjMfNT1Gx-KQ_5PhQI1ZM
# Server-only secret key — used by lib/supabase/admin.ts (e.g. /api/interest).
# Never expose it to the client (do NOT prefix with NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# Contact form delivery (lib/contact.ts → /api/contact, provider: Resend).
# Create a Resend account, verify the steppe.community sending domain (SPF/DKIM
# at Porkbun), then set these. The handler fails gracefully if RESEND_API_KEY is
# absent — the form falls back to the direct mailto: link. Messages are emailed
# to the inbox, never stored in the DB.
RESEND_API_KEY=your-resend-api-key
CONTACT_TO=hello@steppe.community
CONTACT_FROM=Steppe <notify@steppe.community>

# Launch phase gate (lib/supabase/proxy.ts).
#   prelaunch (default) — only the public marketing pages + the /join signup are
#                         served; /auth/* and /protected/* redirect to "/".
#   live                — opens the member app (normal auth gating).
LAUNCH_PHASE=prelaunch

# Canonical site origin for absolute metadata URLs (app/layout.tsx metadataBase —
# OG/Twitter cards, canonical links). Set in prod so shared links resolve to the
# real domain instead of the *.vercel.app machine name. Optional locally.
NEXT_PUBLIC_SITE_URL=https://www.steppe.community