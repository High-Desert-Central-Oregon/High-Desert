# =============================================================================
# TEMPLATE — copy to .env on the box (chmod 600), fill EVERY name, never commit.
#
# ⚠ THE #1 SELF-HOSTING SECURITY MISTAKE is booting with the placeholder values
# from a vendor .env.example (the "super-secret-jwt-token-with-at-least-32..."
# class of default). Anyone on the internet knows those strings; a stack booted
# with them is pre-compromised. This template therefore contains NO example
# values — only names and the command that generates each real one.
# =============================================================================

# --- Postgres -----------------------------------------------------------------
# openssl rand -base64 32
POSTGRES_PASSWORD=

# --- JWT ----------------------------------------------------------------------
# openssl rand -base64 48        (>= 32 chars; GoTrue, PostgREST, Storage share it)
JWT_SECRET=
# ANON_KEY / SERVICE_ROLE_KEY are NOT random strings — they are JWTs signed with
# JWT_SECRET carrying role claims ("anon" / "service_role"). Mint them AFTER
# setting JWT_SECRET, using the Supabase self-hosting JWT generator (docs:
# supabase.com/docs/guides/self-hosting → "API keys"), then paste here.
ANON_KEY=
SERVICE_ROLE_KEY=

# --- URLs ----------------------------------------------------------------------
SITE_URL=https://www.steppe.community
API_EXTERNAL_URL=https://api.steppe.community

# --- App (mirrors steppe/.env.example, values live only here) -------------------
NEXT_PUBLIC_SUPABASE_URL=https://api.steppe.community
# = ANON_KEY above (the publishable key IS the anon JWT in self-host)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=https://www.steppe.community
SUPABASE_SERVICE_ROLE_KEY=
LAUNCH_PHASE=prelaunch
RESEND_API_KEY=
CONTACT_TO=
CONTACT_FROM=

# --- Auth email (GoTrue SMTP — magic links live or die on this) -----------------
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=

# --- DR: pgBackRest → S3-compatible object storage (see dr/README.md) -----------
PGBACKREST_S3_ENDPOINT=
PGBACKREST_S3_BUCKET=
PGBACKREST_S3_REGION=
PGBACKREST_S3_KEY=
PGBACKREST_S3_KEY_SECRET=
# openssl rand -base64 32       (repo encryption passphrase — STORE A COPY OFF-BOX;
# an encrypted backup whose key lived only on the dead box is not a backup)
PGBACKREST_CIPHER_PASS=

# --- DR: off-provider encrypted copy (US-domiciled per the roadmap decision) ----
OFFSITE_S3_ENDPOINT=
OFFSITE_S3_BUCKET=
OFFSITE_S3_KEY=
OFFSITE_S3_KEY_SECRET=
